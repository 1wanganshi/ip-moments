# 演示模式：默认开启。设为 false 后才强制走 Supabase 登录保护。
NEXT_PUBLIC_DEMO_MODE=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI Provider 服务端密钥，不要加 NEXT_PUBLIC_ 前缀
# 支持 OpenAI-compatible 接口，例如：https://coderxiaoc.com
OPENAI_COMPATIBLE_BASE_URL=https://coderxiaoc.com
OPENAI_COMPATIBLE_API_KEY=your-server-side-api-key
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
